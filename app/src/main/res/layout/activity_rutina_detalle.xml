<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F0FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎁 Rutina desbloqueada"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1C1B1F"
            android:gravity="center"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sigue los pasos con calma, uno por uno."
            android:textSize="15sp"
            android:textColor="#49454F"
            android:gravity="center"
            android:layout_marginBottom="22dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="26dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:id="@+id/tvTituloRutina"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Rutina"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#6750A4"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvEspecialistaRutina"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Especialista"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#49454F"
                    android:gravity="center"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🧠 Objetivo"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1C1B1F"
                    android:layout_marginTop="24dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ayudarte a concentrarte mejor y completar una actividad corta sin presión."
                    android:textSize="15sp"
                    android:textColor="#49454F"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✅ Pasos de la rutina"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1C1B1F"
                    android:layout_marginTop="24dp" />

                <TextView
                    android:id="@+id/tvPasosRutina"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pasos"
                    android:textSize="18sp"
                    android:textColor="#1C1B1F"
                    android:lineSpacingExtra="10dp"
                    android:layout_marginTop="10dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnComenzarRutina"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🚀 Comenzar rutina"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#6750A4"
            app:cornerRadius="28dp"
            android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recuerda: no tienes que hacerlo perfecto, solo avanzar un paso."
            android:textSize="14sp"
            android:textColor="#6750A4"
            android:gravity="center"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>