<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F0FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Escanear QR"
            android:textColor="#1C1B1F"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Desbloquea tu rutina sorpresa escaneando un código QR."
            android:textColor="#49454F"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="22dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="26dp">

                <TextView
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:text="📷"
                    android:textSize="54sp"
                    android:gravity="center"
                    android:background="#E8DEF8" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Escáner de rutinas"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#6750A4"
                    android:gravity="center"
                    android:layout_marginTop="18dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Puedes usar la cámara o seleccionar una captura desde tu galería."
                    android:textSize="14sp"
                    android:textColor="#49454F"
                    android:gravity="center"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEscanear"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🔍 Escanear con cámara"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#6750A4"
            app:cornerRadius="28dp"
            android:layout_marginTop="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLeerGaleria"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🖼️ Leer QR desde galería"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#6750A4"
            app:backgroundTint="#FFFFFF"
            app:strokeColor="#6750A4"
            app:strokeWidth="2dp"
            app:cornerRadius="28dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tip: si usas una captura, asegúrate de que el QR se vea completo y claro."
            android:textSize="13sp"
            android:textColor="#6750A4"
            android:gravity="center"
            android:layout_marginBottom="18dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#E8DEF8">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✅ Rutina detectada"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#6750A4" />

                <TextView
                    android:id="@+id/tvResultadoQR"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Modo estudio activado"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#1C1B1F"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIniciarRutina"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="🚀 Iniciar rutina"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#6750A4"
                    app:cornerRadius="18dp"
                    android:layout_marginTop="16dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>